# Generated by `pnpm convex:dev`
CONVEX_DEPLOYMENT=dev:your-project
VITE_CONVEX_URL=https://your-project.convex.cloud
VITE_CONVEX_SITE_URL=https://your-project.convex.site

# Local TanStack Start URL
VITE_SITE_URL=http://localhost:3000

# Strava OAuth (register at https://www.strava.com/settings/api)
# Also set STRAVA_CLIENT_ID and STRAVA_CLIENT_SECRET as Convex env vars:
#   pnpm exec convex env set STRAVA_CLIENT_ID <value>
#   pnpm exec convex env set STRAVA_CLIENT_SECRET <value>
VITE_STRAVA_CLIENT_ID=your-strava-client-id

# OpenAI (for AI chat assistant on activity page)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Stripe (for credits & subscription billing)
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Webhook signing secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# Shared secret for Convex webhook actions (generate any random string)
# Also set as a Convex env var:
#   pnpm exec convex env set STRIPE_WEBHOOK_CONVEX_SECRET <same-value>
STRIPE_WEBHOOK_CONVEX_SECRET=your-random-shared-secret
